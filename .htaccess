Options -Indexes
RewriteEngine On

# Bare root → main site (only the empty path, sub-paths untouched)
RewriteRule ^$ https://meraki.show/ [R=301,L]

# The giveaway / pre-registration now forwards to ticket sales.
# NOTE: only the PAGE root redirects — /preregistration/assets/* keeps serving
# (the tickets page still loads its show photos from there). 302 = reversible.
RewriteRule ^preregistration/?$ /tickets/ [R=302,L]
RewriteRule ^pre-register/?$    /tickets/ [R=302,L]
RewriteRule ^event-2026/?$      /tickets/ [R=302,L,NC]

# Far-future cache for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css         "access plus 10 minutes"
  ExpiresByType application/javascript "access plus 10 minutes"
  ExpiresByType image/jpeg       "access plus 30 days"
  ExpiresByType image/png        "access plus 30 days"
  ExpiresByType image/x-icon     "access plus 30 days"
</IfModule>
